# ===== 后端配置 =====

# 服务端口
PORT=3001

# MySQL 数据库连接
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123
DB_NAME=agent_chat

# Redis 连接
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# LLM 配置（OpenAI 兼容接口）
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# JWT 密钥
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# SMTP 邮件服务（用于 send_email 工具）
# QQ邮箱: SMTP_HOST=smtp.qq.com SMTP_PORT=587
# 163邮箱: SMTP_HOST=smtp.163.com SMTP_PORT=465
# Gmail:   SMTP_HOST=smtp.gmail.com SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=